{
  "sources": ["biorxiv", "medrxiv", "pmc", "arxiv"],
  "search_queries": [
    "machine learning neural networks representation learning",
    "active inference free energy principle",
    "soft matter active nematics topology",
    "dynamical systems bifurcation synchrony",
    "computational biology gene regulatory networks",
    "condensed matter topological phases",
    "econophysics complexity emergence",
    "systems neuroscience connectome",
    "synthetic biology metabolic engineering",
    "quantum information quantum computing"
  ],
  "watch_authors": [
    {
      "name": "Carl Friston",
      "note": "Active inference, free energy principle"
    },
    {
      "name": "Yoshua Bengio",
      "note": "Deep learning, causal representation"
    },
    {
      "name": "Your Author Here",
      "note": "Why you follow this person"
    }
  ],
  "lookback_days": 7,
  "max_papers_per_search": 80,
  "max_author_papers_per_author": 5,
  "ranking": {
    "cross_domain_surprise_weight": 0.40,
    "citation_velocity_weight": 0.25,
    "venue_prestige_weight": 0.15,
    "recency_weight": 0.20,
    "recency_halflife_days": 180
  },
  "credibility_filters": {
    "discard_predatory_journals": true,
    "allow_preprints": true
  },
  "digest_output_file": "digest.md",
  "max_connections_in_digest": 8,
  "email_delivery": {
    "enabled": false,
    "provider": "resend",
    "from": "onboarding@resend.dev",
    "recipients": [
      "you@example.com"
    ],
    "subject_prefix": "Weekly Synthesis",
    "include_sections": ["watched_authors", "connections", "standalone_papers"],
    "fallback_to_gmail_draft": false
  }
}
